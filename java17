import java.util.*;
public class Main
{
    static int count(int n){
     int countb =1;
   for(int i=1;i<=n;i++) {
       countb*=i;
     }
     return countb;
    }
	public static void main(String[] args) {
		Scanner sc=new Scanner(System.in);
		int n=sc.nextInt();
	 System.out.print(count(n));
		
	}
}

import java.util.*;

class Main {

    static void com(int[] arr, int n) {
        Arrays.sort(arr);
        System.out.println(arr[n - 2]);
    }

    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        int n = sc.nextInt();
        int[] arr = new int[n];

        for (int i = 0; i < n; i++) {
            arr[i] = sc.nextInt();
        }

        com(arr, n);
    }
}

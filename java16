import java.util.*;
public class Main {
    static int count(int n) {
        int countb = 0;
        while (n > 0) {
            n = n / 10;
            countb++;
        }
        return countb;
    }
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        int n = sc.nextInt();
        System.out.println(count(n));   
    }
}
